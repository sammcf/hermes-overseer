diff --git a/gateway/run.py b/gateway/run.py
index 716e981..70b6cd0 100644
--- a/gateway/run.py
+++ b/gateway/run.py
@@ -908,6 +908,29 @@ class GatewayRunner:
             except Exception as e:
                 logger.debug("Failed interrupting agent during shutdown: %s", e)
 
+        # Flush memories for sessions not yet captured by the expiry watcher
+        try:
+            for key, entry in list(self.session_store._entries.items()):
+                if entry.session_id not in self.session_store._pre_flushed_sessions:
+                    logger.info(
+                        "Pre-shutdown memory flush for session %s (key=%s)",
+                        entry.session_id, key[:20],
+                    )
+                    try:
+                        await asyncio.wait_for(
+                            self._async_flush_memories(entry.session_id),
+                            timeout=30.0,
+                        )
+                        self.session_store._pre_flushed_sessions.add(entry.session_id)
+                    except asyncio.TimeoutError:
+                        logger.warning(
+                            "Pre-shutdown memory flush timed out for session %s", key[:20]
+                        )
+                    except Exception as e:
+                        logger.debug("Pre-shutdown memory flush failed for %s: %s", key, e)
+        except Exception as e:
+            logger.debug("Pre-shutdown memory flush loop error: %s", e)
+
         for platform, adapter in list(self.adapters.items()):
             try:
                 await adapter.cancel_background_tasks()
