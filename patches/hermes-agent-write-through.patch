+"""Behavioural tests for write-through session DB persistence.
+
+System invariants:
+- After each tool-call turn, _flush_messages_to_session_db is called to write
+  messages to SQLite immediately, not just at session exit.
+- This ensures messages survive crashes/interruptions between turns.
+"""
+
+import os
+import uuid
+from types import SimpleNamespace
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+
+# ---------------------------------------------------------------------------
+# Helpers (mirrored from test_run_agent.py patterns)
+# ---------------------------------------------------------------------------
+
+def _make_tool_defs(*names: str) -> list:
+    return [
+        {
+            "type": "function",
+            "function": {
+                "name": n,
+                "description": f"{n} tool",
+                "parameters": {"type": "object", "properties": {}},
+            },
+        }
+        for n in names
+    ]
+
+
+def _mock_tool_call(name="web_search", arguments="{}", call_id=None):
+    return SimpleNamespace(
+        id=call_id or f"call_{uuid.uuid4().hex[:8]}",
+        type="function",
+        function=SimpleNamespace(name=name, arguments=arguments),
+    )
+
+
+def _mock_assistant_msg(content="", tool_calls=None):
+    return SimpleNamespace(content=content, tool_calls=tool_calls)
+
+
+def _mock_response(content="", finish_reason="stop", tool_calls=None):
+    msg = _mock_assistant_msg(content=content, tool_calls=tool_calls)
+    choice = SimpleNamespace(message=msg, finish_reason=finish_reason)
+    resp = SimpleNamespace(choices=[choice], model="test/model", usage=None)
+    return resp
+
+
+@pytest.fixture()
+def agent():
+    with (
+        patch("run_agent.get_tool_definitions", return_value=_make_tool_defs("web_search")),
+        patch("run_agent.check_toolset_requirements", return_value={}),
+        patch("run_agent.OpenAI"),
+    ):
+        from run_agent import AIAgent
+        a = AIAgent(
+            api_key="test-key-1234567890",
+            quiet_mode=True,
+            skip_context_files=True,
+            skip_memory=True,
+        )
+        a.client = MagicMock()
+        return a
+
+
+def _setup_agent(a):
+    a._cached_system_prompt = "You are helpful."
+    a._use_prompt_caching = False
+    a.tool_delay = 0
+    a.compression_enabled = False
+    a.save_trajectories = False
+
+
+# ---------------------------------------------------------------------------
+# TestWriteThroughPersistence
+# ---------------------------------------------------------------------------
+
+
+class TestWriteThroughPersistence:
+    """_flush_messages_to_session_db is called after each tool-call turn, not just at exit."""
+
+    def test_db_flushed_after_tool_call_turn(self, agent):
+        """Mid-loop flush occurs once per tool-call turn before final persist."""
+        _setup_agent(agent)
+
+        flush_call_counts: list[int] = []
+        original_flush = agent._flush_messages_to_session_db
+
+        def spy(messages, conversation_history=None):
+            flush_call_counts.append(len(messages))
+            return original_flush(messages, conversation_history)
+
+        agent._flush_messages_to_session_db = spy
+
+        tc = _mock_tool_call(name="web_search", call_id="c1")
+        resp1 = _mock_response(content="", finish_reason="tool_calls", tool_calls=[tc])
+        resp2 = _mock_response(content="Done searching", finish_reason="stop")
+        agent.client.chat.completions.create.side_effect = [resp1, resp2]
+
+        with (
+            patch("run_agent.handle_function_call", return_value="result"),
+            patch.object(agent, "_save_session_log"),
+            patch.object(agent, "_save_trajectory"),
+            patch.object(agent, "_cleanup_task_resources"),
+        ):
+            agent.run_conversation(user_message="search something")
+
+        # Before fix: called once (only at _persist_session at session end)
+        # After fix: called at least twice (mid-loop after tool turn + final persist)
+        assert len(flush_call_counts) >= 2, (
+            f"Expected >=2 flush calls (mid-loop + final) but got {len(flush_call_counts)}. "
+            "The write-through fix adds _flush_messages_to_session_db after _save_session_log "
+            "in the tool-call continuation path."
+        )
+
+    def test_messages_present_in_db_between_turns(self, tmp_path):
+        """Tool-call turn messages are in SQLite before the next API call."""
+        from hermes_state import SessionDB
+
+        db_path = tmp_path / "wt_test.db"
+        db = SessionDB(db_path=db_path)
+
+        with (
+            patch("run_agent.get_tool_definitions", return_value=_make_tool_defs("web_search")),
+            patch("run_agent.check_toolset_requirements", return_value={}),
+            patch("run_agent.OpenAI"),
+        ):
+            from run_agent import AIAgent
+            a = AIAgent(
+                api_key="test-key-1234567890",
+                quiet_mode=True,
+                skip_context_files=True,
+                skip_memory=True,
+                session_db=db,
+                session_id="wt-test-session",
+            )
+        a.client = MagicMock()
+        _setup_agent(a)
+
+        # Capture DB state after tool execution (between turns)
+        db_state_after_tool_turn: list[int] = []
+
+        original_save = a._save_session_log
+
+        def capture_after_tool_log(messages):
+            original_save(messages)
+            # If a tool call turn just completed, check DB state
+            if any(m.get("role") == "tool" for m in messages):
+                rows = db.get_messages("wt-test-session")
+                db_state_after_tool_turn.append(len(rows))
+
+        a._save_session_log = capture_after_tool_log
+
+        tc = _mock_tool_call(name="web_search", call_id="c2")
+        resp1 = _mock_response(content="", finish_reason="tool_calls", tool_calls=[tc])
+        resp2 = _mock_response(content="All done", finish_reason="stop")
+        a.client.chat.completions.create.side_effect = [resp1, resp2]
+
+        with (
+            patch("run_agent.handle_function_call", return_value="tool output"),
+            patch.object(a, "_save_trajectory"),
+            patch.object(a, "_cleanup_task_resources"),
+        ):
+            a.run_conversation(user_message="do something")
+
+        # Before fix: DB empty between turns (only flushed at session end)
+        # After fix: DB has messages after tool-call turn
+        assert db_state_after_tool_turn, "Tool-call turn path was not exercised"
+        assert db_state_after_tool_turn[-1] > 0, (
+            f"DB had {db_state_after_tool_turn[-1]} messages after tool-call turn. "
+            "Expected > 0 — write-through should flush immediately after each tool turn."
+        )
+
+    def test_two_tool_turns_each_triggers_flush(self, agent):
+        """With two sequential tool-call turns, flush is called at least 3 times."""
+        _setup_agent(agent)
+
+        flush_call_counts: list[int] = []
+        original_flush = agent._flush_messages_to_session_db
+
+        def spy(messages, conversation_history=None):
+            flush_call_counts.append(len(messages))
+            return original_flush(messages, conversation_history)
+
+        agent._flush_messages_to_session_db = spy
+
+        tc1 = _mock_tool_call(name="web_search", call_id="c1")
+        tc2 = _mock_tool_call(name="web_search", call_id="c2")
+        resp1 = _mock_response(content="", finish_reason="tool_calls", tool_calls=[tc1])
+        resp2 = _mock_response(content="", finish_reason="tool_calls", tool_calls=[tc2])
+        resp3 = _mock_response(content="Finished", finish_reason="stop")
+        agent.client.chat.completions.create.side_effect = [resp1, resp2, resp3]
+
+        with (
+            patch("run_agent.handle_function_call", return_value="result"),
+            patch.object(agent, "_save_session_log"),
+            patch.object(agent, "_save_trajectory"),
+            patch.object(agent, "_cleanup_task_resources"),
+        ):
+            agent.run_conversation(user_message="two-step task")
+
+        # Before fix: 1 flush (final persist only)
+        # After fix: ≥3 flushes (one per tool-call turn + final persist)
+        assert len(flush_call_counts) >= 3, (
+            f"Expected >=3 flush calls for 2 tool turns but got {len(flush_call_counts)}."
+        )
