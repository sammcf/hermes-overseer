+
+
+@pytest.mark.asyncio
+async def test_stop_flushes_memories_for_unflushed_active_sessions():
+    """stop() triggers memory flush for any session not yet captured by expiry watcher."""
+    runner = object.__new__(GatewayRunner)
+    runner._running = True
+    runner._shutdown_event = asyncio.Event()
+    runner._exit_reason = None
+    runner._pending_messages = {}
+    runner._pending_approvals = {}
+    runner._shutdown_all_gateway_honcho = lambda: None
+    runner._running_agents = {}
+    runner.adapters = {}
+
+    # One unflushed session in the store
+    entry = SessionEntry(
+        session_key="agent:main:telegram:dm",
+        session_id="sid_unflushed",
+        created_at=datetime.now(),
+        updated_at=datetime.now(),
+        platform=Platform.TELEGRAM,
+        chat_type="dm",
+    )
+    pre_flushed: set[str] = set()
+
+    session_store_mock = MagicMock()
+    session_store_mock._entries = {"agent:main:telegram:dm": entry}
+    session_store_mock._pre_flushed_sessions = pre_flushed
+    runner.session_store = session_store_mock
+
+    flush_calls: list[str] = []
+
+    async def mock_async_flush(session_id: str) -> None:
+        flush_calls.append(session_id)
+
+    runner._async_flush_memories = mock_async_flush
+
+    with patch("gateway.status.remove_pid_file"), patch("gateway.status.write_runtime_status"):
+        await runner.stop()
+
+    # Before fix: flush_calls is empty (stop() never flushed memories)
+    # After fix: flush_calls contains the unflushed session id
+    assert "sid_unflushed" in flush_calls, (
+        f"Expected stop() to flush memories for unflushed session but flush_calls={flush_calls}. "
+        "Add a memory flush loop to GatewayRunner.stop() before adapters are disconnected."
+    )
+
+
+@pytest.mark.asyncio
+async def test_stop_skips_already_flushed_sessions():
+    """stop() skips sessions already captured by the proactive expiry watcher."""
+    runner = object.__new__(GatewayRunner)
+    runner._running = True
+    runner._shutdown_event = asyncio.Event()
+    runner._exit_reason = None
+    runner._pending_messages = {}
+    runner._pending_approvals = {}
+    runner._shutdown_all_gateway_honcho = lambda: None
+    runner._running_agents = {}
+    runner.adapters = {}
+
+    entry = SessionEntry(
+        session_key="agent:main:telegram:dm",
+        session_id="sid_already_flushed",
+        created_at=datetime.now(),
+        updated_at=datetime.now(),
+        platform=Platform.TELEGRAM,
+        chat_type="dm",
+    )
+    # Mark it as already flushed
+    pre_flushed: set[str] = {"sid_already_flushed"}
+
+    session_store_mock = MagicMock()
+    session_store_mock._entries = {"agent:main:telegram:dm": entry}
+    session_store_mock._pre_flushed_sessions = pre_flushed
+    runner.session_store = session_store_mock
+
+    flush_calls: list[str] = []
+
+    async def mock_async_flush(session_id: str) -> None:
+        flush_calls.append(session_id)
+
+    runner._async_flush_memories = mock_async_flush
+
+    with patch("gateway.status.remove_pid_file"), patch("gateway.status.write_runtime_status"):
+        await runner.stop()
+
+    assert "sid_already_flushed" not in flush_calls, (
+        "stop() should NOT re-flush sessions already in _pre_flushed_sessions."
+    )
